# Copy this file to .env and fill in the values before running docker-compose.
#
#   cp .env.example .env
#   $EDITOR .env
#
# NEVER commit .env to version control.

# ── JWT ───────────────────────────────────────────────────────────────────────
# Required. Minimum 32 characters. Generate with:
#   openssl rand -base64 32
APP_JWT_SECRET=change-me-to-a-random-32-char-secret!!

# Token lifetime (default 24h). Use shorter values in production.
APP_JWT_EXPIRY=24h

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=chat
POSTGRES_USER=chat
POSTGRES_PASSWORD=change-me-strong-password

# Copy this file to .env and fill in the values before running docker-compose.
#
#   cp .env.example .env
#   $EDITOR .env
#
# NEVER commit .env to version control.

# ── JWT ───────────────────────────────────────────────────────────────────────
# Required. Minimum 32 characters. Generate with:
#   openssl rand -base64 32
APP_JWT_SECRET=change-me-to-a-random-32-char-secret!!

# Token lifetime (default 24h). Use shorter values in production.
APP_JWT_EXPIRY=24h

# ── WebSocket origin allowlist ────────────────────────────────────────────────
# Comma-separated list of allowed origins for WebSocket upgrades.
# Leave empty for same-host check only (recommended for production).
# Use "*" only for local development without a reverse proxy.
# Example: APP_SERVER_ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
APP_SERVER_ALLOWED_ORIGINS=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=chat
POSTGRES_USER=chat
POSTGRES_PASSWORD=change-me-strong-password
